use() { return 0; }
extern() { return 0; }
legacy() { return 0; }
module() { return 0; }
public() { return 0; }
embed() { return 0; }
inject() { return 0; }

# @section_code: SC007
# @section_name: source
# @source_index: 1
# @source_file: src/main.sh
# @portion_type: entrypoint

module http

btproxy_load_rc_file() {
  local file; file="$1"
  [ -f "$file" ] || return 0

  local line
  local key
  local value

  while IFS= read -r line || [ -n "$line" ]; do
    line="${line#"${line%%[![:space:]]*}"}"
    line="${line%"${line##*[![:space:]]}"}"

    [ -z "$line" ] && continue
    case "$line" in
      \#*) continue ;;
      export\ *) line="${line#export }" ;;
    esac

    case "$line" in
      *=*)
        key="${line%%=*}"
        value="${line#*=}"
        ;;
      *)
        continue
        ;;
    esac

    key="${key%"${key##*[![:space:]]}"}"
    key="${key#"${key%%[![:space:]]*}"}"
    [ -z "$key" ] && continue

    case "$key" in
      BTPROXY_*)
        value="${value#"${value%%[![:space:]]*}"}"
        value="${value%"${value##*[![:space:]]}"}"
        if [ "${value#\"}" != "$value" ] && [ "${value%\"}" != "$value" ]; then
          value="${value#\"}"
          value="${value%\"}"
        elif [ "${value#\'}" != "$value" ] && [ "${value%\'}" != "$value" ]; then
          value="${value#\'}"
          value="${value%\'}"
        fi
        export "$key=$value"
        ;;
    esac
  done < "$file"
}

btproxy_load_rc() {
  local home_file; home_file="${HOME:-}/.btproxyrc"
  local pwd_file; pwd_file="${PWD}/.btproxyrc"

  if [ -n "${HOME:-}" ]; then
    btproxy_load_rc_file "$home_file"
  fi

  btproxy_load_rc_file "$pwd_file"
}

btproxy_is_full_uuid() {
  local value; value="$1"
  [[ "$value" =~ ^[[:xdigit:]]{8}-[[:xdigit:]]{4}-[[:xdigit:]]{4}-[[:xdigit:]]{4}-[[:xdigit:]]{12}$ ]]
}

btproxy_uuid_matches_input() {
  local uuid; uuid=$(printf '%s' "$1" | tr '[:lower:]' '[:upper:]')
  local input; input=$(printf '%s' "$2" | tr '[:lower:]' '[:upper:]')

  local uuid_compact="${uuid//-/}"
  local input_compact="${input//-/}"

  case "$uuid" in
    "$input"*) return 0 ;;
  esac

  case "$uuid_compact" in
    "$input_compact"*) return 0 ;;
  esac

  case "$uuid" in
    0000????-0000-1000-8000-00805F9B34FB)
      local short4="${uuid#0000}"
      short4="${short4%%-*}"

      case "$short4" in
        "$input"*) return 0 ;;
      esac

      local short_trimmed="$short4"
      while [ "${short_trimmed#0}" != "$short_trimmed" ]; do
        short_trimmed="${short_trimmed#0}"
      done
      [ -z "$short_trimmed" ] && short_trimmed="0"

      case "$short_trimmed" in
        "$input"*) return 0 ;;
      esac
      ;;
  esac

  return 1
}

btproxy_resolve_characteristic() {
  local base_url; base_url="$1"
  local mac; mac="$2"
  local input; input="$3"

  if btproxy_is_full_uuid "$input"; then
    printf '%s' "$input"
    return 0
  fi

  local listing
  listing=$(btproxy_http_get_auth_plain "$base_url/devices/$mac/characteristics") || {
    echo "ERROR: unable to resolve characteristic '$input': failed to fetch characteristic list" >&2
    return 1
  }

  local line
  local uuid
  local matched=""
  local matches=0

  while IFS= read -r line; do
    case "$line" in
      *characteristic:\ *)
        uuid="${line#*characteristic: }"
        uuid="${uuid%% properties:*}"
        uuid="${uuid%% *}"
        if btproxy_uuid_matches_input "$uuid" "$input"; then
          matched="$uuid"
          matches=$((matches + 1))
        fi
        ;;
    esac
  done <<EOF
$listing
EOF

  if [ "$matches" -eq 1 ]; then
    printf '%s' "$matched"
    return 0
  fi

  if [ "$matches" -eq 0 ]; then
    echo "ERROR: no characteristic matches '$input' on device '$mac'" >&2
    return 1
  fi

  echo "ERROR: characteristic '$input' is ambiguous on device '$mac'" >&2
  while IFS= read -r line; do
    case "$line" in
      *characteristic:\ *)
        uuid="${line#*characteristic: }"
        uuid="${uuid%% properties:*}"
        uuid="${uuid%% *}"
        if btproxy_uuid_matches_input "$uuid" "$input"; then
          echo "  $uuid" >&2
        fi
        ;;
    esac
  done <<EOF
$listing
EOF
  return 1
}

btproxy_hex_to_ascii() {
  local bytes; bytes="$1"
  local byte
  local escape
  local out=""

  for byte in $bytes; do
    byte=$(printf '%s' "$byte" | tr '[:lower:]' '[:upper:]')
    case "$byte" in
      [0-9A-F][0-9A-F]) ;;
      *) continue ;;
    esac

    [ "$byte" = "00" ] && continue

    printf -v escape '\\x%s' "$byte"
    out="${out}$(printf '%b' "$escape")"
  done

  printf '%s\n' "$out"
}

btproxy_hex_to_uint16_le() {
  local bytes; bytes="$1"
  local filtered=()
  local byte
  local i
  local low
  local high
  local value
  local out=""

  for byte in $bytes; do
    byte=$(printf '%s' "$byte" | tr '[:lower:]' '[:upper:]')
    case "$byte" in
      [0-9A-F][0-9A-F]) filtered+=("$byte") ;;
    esac
  done

  if [ $(( ${#filtered[@]} % 2 )) -ne 0 ]; then
    echo "ERROR: cannot decode little-endian uint16 values from an odd number of bytes" >&2
    return 1
  fi

  i=0
  while [ "$i" -lt "${#filtered[@]}" ]; do
    low="${filtered[$i]}"
    high="${filtered[$((i + 1))]}"
    value=$((16#$high * 256 + 16#$low))
    if [ -n "$out" ]; then
      out="$out, "
    fi
    out="${out}${value}"
    i=$((i + 2))
  done

  printf '[%s]\n' "$out"
}

main() {
  btproxy_load_rc

  local base_url; base_url="${BTPROXY_URL:-}"

  if [ -z "$base_url" ]; then
    echo "ERROR: BTPROXY_URL is not set" >&2
    echo "  e.g. export BTPROXY_URL=http://192.168.1.1:8080" >&2
    exit 1
  fi

  local debug; debug=0
  local output_mode; output_mode="raw"
  while true; do
    case "${1:-}" in
      --debug)
        debug=1
        shift
        ;;
      --ascii)
        output_mode="ascii"
        shift
        ;;
      --little-endian)
        output_mode="little-endian"
        shift
        ;;
      *)
        break
        ;;
    esac
  done

  local cmd; cmd="${1:-}"
  shift || true

  case "$cmd" in
    ping)
      btproxy_http_get "$base_url/ping" "$debug"
      ;;
    health)
      btproxy_http_get "$base_url/health" "$debug"
      ;;
    status)
      btproxy_http_get "$base_url/status" "$debug"
      ;;
    l|list)
      btproxy_http_get "$base_url/devices" "$debug"
      ;;
    c|characteristics)
      local mac_input; mac_input="${1:-}"
      if [ -z "$mac_input" ]; then
        echo "Usage: btproxy characteristics|c <mac-or-prefix>" >&2
        exit 1
      fi
      local mac; mac=$(btproxy_resolve_mac "$base_url" "$mac_input") || exit $?
      btproxy_http_get_auth "$base_url/devices/$mac/characteristics" "$debug"
      ;;
    r|read)
      local mac_input; mac_input="${1:-}"
      local uuid_input; uuid_input="${2:-}"
      if [ -z "$mac_input" ] || [ -z "$uuid_input" ]; then
        echo "Usage: btproxy read|r <mac-or-prefix> <uuid>" >&2
        exit 1
      fi
      shift 2 || true
      local read_output_mode; read_output_mode="$output_mode"
      while [ "$#" -gt 0 ]; do
        case "$1" in
          --ascii)
            read_output_mode="ascii"
            ;;
          --little-endian)
            read_output_mode="little-endian"
            ;;
          *)
            echo "Usage: btproxy read|r <mac-or-prefix> <uuid> [--ascii|--little-endian]" >&2
            exit 1
            ;;
        esac
        shift
      done
      local mac; mac=$(btproxy_resolve_mac "$base_url" "$mac_input") || exit $?
      local uuid; uuid=$(btproxy_resolve_characteristic "$base_url" "$mac" "$uuid_input") || exit $?
      if [ "$read_output_mode" != "raw" ]; then
        local value
        value=$(btproxy_http_get_auth_plain "$base_url/$mac/$uuid") || exit $?
        case "$read_output_mode" in
          ascii)
            btproxy_hex_to_ascii "$value"
            ;;
          little-endian)
            btproxy_hex_to_uint16_le "$value"
            ;;
        esac
      else
        btproxy_http_get_auth "$base_url/$mac/$uuid" "$debug"
      fi
      ;;
    w|write)
      local mac_input; mac_input="${1:-}"
      local uuid_input; uuid_input="${2:-}"
      if [ -z "$mac_input" ] || [ -z "$uuid_input" ]; then
        echo "Usage: btproxy write|w <mac-or-prefix> <hex bytes...>" >&2
        exit 1
      fi
      shift 2
      local body; body="$*"
      if [ -z "$body" ]; then
        echo "Usage: btproxy write|w <mac-or-prefix> <uuid> <hex bytes...>" >&2
        echo "  e.g. btproxy w AA 00002a37-0000-1000-8000-00805f9b34fb A0 81 D0" >&2
        exit 1
      fi
      local mac; mac=$(btproxy_resolve_mac "$base_url" "$mac_input") || exit $?
      local uuid; uuid=$(btproxy_resolve_characteristic "$base_url" "$mac" "$uuid_input") || exit $?
      btproxy_http_post_auth "$base_url/$mac/$uuid" "$body" "$debug"
      ;;
    ""|help|--help|-h)
      echo "btproxy - CLI for the BTProxy Android app"
      echo ""
      echo "Usage: btproxy [--debug] <command> [args...]"
      echo ""
      echo "Commands:"
      echo "  ping                          Liveness check (no auth)"
      echo "  health                        Health status and connected device count"
      echo "  status                        Server status with connected MAC addresses"
      echo "  list|l                        List connected BLE device MAC addresses"
      echo "  characteristics|c <mac>       List GATT services and characteristics"
      echo "  read|r  <mac> <uuid>          Read a BLE GATT characteristic"
      echo "  write|w <mac> <uuid> <hex...> Write a BLE GATT characteristic"
      echo ""
      echo "Environment:"
      echo "  BTPROXY_URL    Base URL of the BTProxy server (required)"
      echo "                 e.g. export BTPROXY_URL=http://192.168.144.7:8080"
      echo "  BTPROXY_SECRET Auth token for authenticated commands (default: secret)"
      echo "  BTPROXY_TOKEN  Auth token fallback if BTPROXY_SECRET is not set"
      echo ""
      echo "Config Files:"
      echo "  ~/.btproxyrc   Loaded first if present"
      echo "  ./.btproxyrc   Loaded after home and overrides it"
      echo "                 Only BTPROXY_* entries are applied"
      echo ""
      echo "Options:"
      echo "  --debug        Show full HTTP request/response payload"
      echo "  --ascii        For read, decode hex bytes to ASCII text"
      echo "  --little-endian For read, decode bytes as uint16 little-endian"
      echo ""
      echo "MAC Resolution:"
      echo "  For c/r/w, you can pass a MAC prefix instead of the full address."
      echo "  The prefix match is case-insensitive and must identify exactly one"
      echo "  connected device from 'btproxy list'."
      echo ""
      echo "Characteristic Resolution:"
      echo "  For r/w, you can pass a UUID prefix or a short form like 2a00."
      echo "  If exactly one discovered characteristic matches on the device,"
      echo "  the CLI resolves it automatically."
      echo ""
      echo "Examples:"
      echo "  btproxy list"
      echo "  btproxy c AA:BB"
      echo "  btproxy r a 2a00 --ascii"
      echo "  btproxy r a 2a00 --little-endian"
      echo "  btproxy w AA 00002a37-0000-1000-8000-00805f9b34fb A0 81 D0"
      ;;
    *)
      echo "ERROR: unknown command '$cmd'" >&2
      echo "Run 'btproxy help' for usage." >&2
      exit 1
      ;;
  esac
}

btproxy_is_full_mac() {
  local value; value="$1"
  [[ "$value" =~ ^([[:xdigit:]]{2}:){5}[[:xdigit:]]{2}$ ]]
}

btproxy_resolve_mac() {
  local base_url; base_url="$1"
  local input; input="$2"

  if btproxy_is_full_mac "$input"; then
    printf '%s' "$input"
    return 0
  fi

  local devices; devices=$(btproxy_http_get_plain "$base_url/devices") || {
    echo "ERROR: unable to resolve MAC prefix '$input': failed to fetch device list" >&2
    return 1
  }

  local input_upper; input_upper=$(printf '%s' "$input" | tr '[:lower:]' '[:upper:]')
  local device
  local device_upper
  local matched=""
  local matches=0

  while IFS= read -r device; do
    [ -z "$device" ] && continue
    device_upper=$(printf '%s' "$device" | tr '[:lower:]' '[:upper:]')
    case "$device_upper" in
      "$input_upper"*)
        matched="$device"
        matches=$((matches + 1))
        ;;
    esac
  done <<EOF
$devices
EOF

  if [ "$matches" -eq 1 ]; then
    printf '%s' "$matched"
    return 0
  fi

  if [ "$matches" -eq 0 ]; then
    echo "ERROR: no connected device matches MAC prefix '$input'" >&2
    return 1
  fi

  echo "ERROR: MAC prefix '$input' is ambiguous" >&2
  while IFS= read -r device; do
    [ -z "$device" ] && continue
    device_upper=$(printf '%s' "$device" | tr '[:lower:]' '[:upper:]')
    case "$device_upper" in
      "$input_upper"*)
        echo "  $device" >&2
        ;;
    esac
  done <<EOF
$devices
EOF
  return 1
}

# @section_code: SC007
# @section_name: source
# @source_index: 2
# @source_file: src/http.sh
# @portion_type: module

_btproxy_http_curl_flags() {
  local debug; debug="${1:-0}"
  if [ "$debug" = "1" ]; then
    echo "-v"
  else
    echo "-s"
  fi
}

btproxy_http_get() {
  local url; url="$1"
  local debug; debug="${2:-0}"
  local flags; flags=$(_btproxy_http_curl_flags "$debug")
  local status; status=0
  curl $flags "$url" 2>&1 || status=$?
  printf '\n'
  return "$status"
}

btproxy_http_get_auth() {
  local url; url="$1"
  local debug; debug="${2:-0}"
  local token; token="${BTPROXY_SECRET:-${BTPROXY_TOKEN:-secret}}"
  local flags; flags=$(_btproxy_http_curl_flags "$debug")
  local status; status=0
  curl $flags -H "X-BtProxy: $token" "$url" 2>&1 || status=$?
  printf '\n'
  return "$status"
}

btproxy_http_post_auth() {
  local url; url="$1"
  local body; body="$2"
  local debug; debug="${3:-0}"
  local token; token="${BTPROXY_SECRET:-${BTPROXY_TOKEN:-secret}}"
  local flags; flags=$(_btproxy_http_curl_flags "$debug")
  local status; status=0
  curl $flags -X POST -H "X-BtProxy: $token" -H "Content-Type: text/plain" --data "$body" "$url" 2>&1 || status=$?
  printf '\n'
  return "$status"
}

btproxy_http_get_plain() {
  local url; url="$1"
  curl -sS "$url"
}

btproxy_http_get_auth_plain() {
  local url; url="$1"
  local token; token="${BTPROXY_SECRET:-${BTPROXY_TOKEN:-secret}}"
  curl -sS -H "X-BtProxy: $token" "$url"
}

# @section_code: SC006
# @section_name: entrypoint
main "$@"
